---
import { getCollection, render } from 'astro:content';
import {
  Box,
  Code2,
  Database,
  ExternalLink,
  FileCode2,
  Github,
  Globe2,
  Layers3,
  Palette,
  Rocket,
  Sparkles,
  Terminal,
  WandSparkles,
} from 'lucide-astro';
import FormattedDate from '../../components/FormattedDate.astro';
import BlogArticle from '../../layouts/BlogArticle.astro';
import { getSiteConfig } from '../../data/site';
import navfolioConfig from '../../../navfolio.config';
import { getPageModuleRoute } from '../../plugins/config';
import { sortBlogPostsForArchive } from '../../utils/content-dates';
import { getI18n } from '../../utils/ui-text';

const siteConfig = await getSiteConfig();
const { pages } = siteConfig;
const pageMeta = pages.projects;
const projectEntries = await getCollection('projects');
const projectIndex = projectEntries.find((entry) => entry.id === 'index');
const projects = sortBlogPostsForArchive(
  projectEntries.filter((entry) => entry.id !== 'index' && !entry.data.draft),
);

if (!projectIndex) {
  throw new Error('Missing src/content/projects/index.mdx content entry.');
}

const { Content, headings } = await render(projectIndex);
const projectIndexPage = {
  ...projectIndex,
  data: {
    ...projectIndex.data,
    title: pageMeta.title,
    description: pageMeta.subtitle,
  },
};

const relatedProjects = projects;
const projectsRoute = getPageModuleRoute(navfolioConfig, 'projects');
const i18n = getI18n(siteConfig);

const projectIcons = {
  github: Github,
  box: Box,
  'code-2': Code2,
  database: Database,
  'file-code-2': FileCode2,
  'globe-2': Globe2,
  'layers-3': Layers3,
  palette: Palette,
  rocket: Rocket,
  sparkles: Sparkles,
  terminal: Terminal,
  'wand-sparkles': WandSparkles,
};

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<BlogArticle
  post={projectIndexPage}
  headings={headings}
  sidebar={{ enable: false, ...projectIndex.data.sidebar }}
  headerVariant="archive"
  headerKicker={pageMeta.kicker}
  headerNote={pageMeta.note}
  contentFont="ui"
>
  <Content />

  {
    relatedProjects.length > 0 ? (
      <section class="project-grid" aria-label={i18n.t('projects.listLabel')}>
        {relatedProjects.map((project) => {
          const ProjectIcon = projectIcons[project.data.icon] ?? Github;
          const projectHref = withBase(`${projectsRoute}/${project.id}/`);

          return (
            <article
              class="project-card"
              style={
                project.data.iconColor
                  ? `--project-icon-color: ${project.data.iconColor}`
                  : undefined
              }
            >
              <div class="project-card-heading">
                <ProjectIcon class="project-icon" size={22} strokeWidth={1.55} aria-hidden="true" />
                <h2>
                  <a href={projectHref}>{project.data.title}</a>
                </h2>
              </div>
              <p>{project.data.description}</p>
              <footer class="project-card-footer">
                <span class="project-meta">
                  <FormattedDate date={project.data.date} />
                </span>
                {project.data.authors.length > 0 && (
                  <span class="project-authors" aria-label={i18n.t('projects.authorsLabel')}>
                    {project.data.authors.map((author) =>
                      author.url ? (
                        <a href={author.url}>{author.name}</a>
                      ) : (
                        <span>{author.name}</span>
                      ),
                    )}
                  </span>
                )}
                {project.data.links.length > 0 && (
                  <span class="project-links" aria-label={i18n.t('projects.linksLabel')}>
                    {project.data.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noreferrer">
                        {link.kind === 'github' ? (
                          <Github size={13} strokeWidth={1.8} aria-hidden="true" />
                        ) : (
                          <ExternalLink size={13} strokeWidth={1.8} aria-hidden="true" />
                        )}
                        {link.label}
                      </a>
                    ))}
                  </span>
                )}
                {project.data.tags.length > 0 && (
                  <span class="project-tags" aria-label={i18n.t('projects.tagsLabel')}>
                    {project.data.tags.slice(0, 3).map((tag) => (
                      <small>{tag}</small>
                    ))}
                  </span>
                )}
              </footer>
            </article>
          );
        })}
      </section>
    ) : (
      <section class="project-empty" aria-label={i18n.t('projects.emptyLabel')}>
        <span aria-hidden="true">01</span>
        <h2>{i18n.t('projects.emptyTitle')}</h2>
        <p>{i18n.t('projects.emptyNote')}</p>
      </section>
    )
  }
</BlogArticle>

<style>
  .project-meta,
  .project-authors,
  .project-links,
  .project-empty span,
  .project-tags small {
    font-family: var(--font-ui-label);
  }

  .project-card p,
  .project-empty p {
    margin: 0;
    color: var(--paper-ink-soft);
    line-height: 1.78;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(12px, 2vw, 22px);
    margin-top: 34px;
  }

  .project-card {
    display: grid;
    gap: 14px;
    min-height: 196px;
    padding: 16px;
    color: var(--paper-ink);
    font-family: var(--font-ui-label);
    border-radius: 8px;
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .project-card:hover {
    background: var(--paper-control-hover);
    transform: translateY(-1px);
  }

  .project-card-heading {
    display: flex;
    gap: 11px;
    align-items: center;
  }
  .project-icon {
    flex: none;
    color: var(--project-icon-color, var(--paper-accent));
  }

  .project-meta,
  .project-empty span {
    color: var(--paper-ink-faint);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .project-card h2,
  .project-empty h2 {
    margin: 0;
    color: var(--paper-ink);
    font-family: var(--font-ui-label);
    font-size: 1.32rem;
    line-height: 1.28;
  }

  .project-card h2 a {
    color: inherit;
    display: -webkit-box;
    overflow: hidden;
    text-decoration: none;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }
  .project-card h2 a:hover {
    color: var(--paper-accent);
  }

  .project-card p {
    max-width: 58ch;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .project-card-footer,
  .project-tags,
  .project-authors,
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .project-card-footer {
    display: -webkit-box;
    align-self: end;
    overflow: hidden;
    gap: 8px 12px;
    line-height: 1.6;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .project-card-footer > * {
    display: inline-flex;
    vertical-align: middle;
  }

  .project-card-footer > * + * {
    margin-left: 12px;
  }

  .project-authors,
  .project-links {
    color: var(--paper-ink-faint);
    display: inline-flex;
    font-size: 0.72rem;
  }

  .project-authors > * + *::before {
    content: '·';
    margin-right: 8px;
    color: var(--paper-line-strong);
  }
  .project-authors a,
  .project-links a {
    color: inherit;
    text-decoration: none;
  }
  .project-authors a:hover,
  .project-links a:hover {
    color: var(--paper-accent);
  }
  .project-links a {
    display: inline-flex;
    gap: 4px;
    align-items: center;
  }

  .project-tags small {
    max-width: 12ch;
    overflow: hidden;
    padding: 3px 8px;
    border: 1px solid var(--paper-line);
    border-radius: 999px;
    color: var(--paper-ink-soft);
    font-size: 0.74rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project-empty {
    display: grid;
    gap: 10px;
    max-width: 680px;
    margin-top: 34px;
    padding: 24px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-surface);
    box-shadow: var(--paper-shadow);
  }

  @media (max-width: 720px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card,
    .project-empty {
      padding: 20px;
    }
  }
</style>
