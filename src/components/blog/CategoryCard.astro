---
import ThemeCategoryCard from '@navfolio/theme-default/components/CategoryCard.astro';
import { getSiteConfig } from '../../data/site';
import { uncategorizedCategory } from '../../utils/content-groups';
import { getUiText } from '../../utils/ui-text';

interface Props {
  name: string;
  slug: string;
  count: number;
}

const { name, slug, count } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${basePath}/blog/categories/${slug}/`;
const ui = getUiText(await getSiteConfig());
const displayName = slug === uncategorizedCategory.slug ? ui.groups.uncategorized : name;
---

<ThemeCategoryCard
  href={href}
  categoryLabel={ui.groups.category}
  name={displayName}
  articleCount={ui.groups.articleCount(count)}
/>
