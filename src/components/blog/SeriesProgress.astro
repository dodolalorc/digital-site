---
import ThemeSeriesProgress from '@navfolio/theme-default/components/SeriesProgress.astro';
import { getSiteConfig } from '../../data/site';
import { getUiText } from '../../utils/ui-text';

interface Props {
  current: number;
  total: number;
}

const { current, total } = Astro.props;
const safeTotal = Math.max(1, total);
const percent = Math.round((current / safeTotal) * 100);
const ui = getUiText(await getSiteConfig());
---

<ThemeSeriesProgress
  label={ui.groups.publishedArticles(current)}
  copy={ui.groups.publishedCount(current)}
  percent={percent}
/>
