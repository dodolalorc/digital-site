---
import { Heart, Link2, Share2, ThumbsDown } from 'lucide-astro';
import '@navfolio/theme-default/styles/blog-bottom-action-bar.css';
---

<div class="bottom-action-bar" aria-label="Article feedback actions">
  <span>Was this helpful?</span>
  <button type="button" aria-label="Like article">
    <Heart size={17} />
  </button>
  <button type="button" aria-label="Dislike article">
    <ThumbsDown size={17} />
  </button>
  <button type="button" aria-label="Share article">
    <Share2 size={17} />
  </button>
  <button type="button" aria-label="Copy article link">
    <Link2 size={17} />
  </button>
</div>
