---
import type { ImageMetadata } from 'astro';
import ThemeBaseHead from '@navfolio/theme-default/components/BaseHead.astro';
import FallbackImage from '../assets/figure/fail-loading-image.png';
import { getSiteConfig } from '../data/site';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata | string;
}

const { title, description, image } = Astro.props;
const { site, fonts } = await getSiteConfig();
---

<ThemeBaseHead
  title={title}
  description={description}
  image={image}
  fallbackImage={FallbackImage}
  site={site}
  fonts={fonts}
/>
